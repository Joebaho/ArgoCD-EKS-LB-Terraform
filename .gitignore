# macOS
.DS_Store

# Terraform local working directories
**/.terraform/*

# Terraform state and backups
*.tfstate
*.tfstate.*

# Terraform crash logs
crash.log
crash.*.log

# Terraform plan files
*.tfplan
*.plan

# Terraform override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config and local variable files that often contain secrets
.terraformrc
terraform.rc
*.auto.tfvars
*.auto.tfvars.json
